// 1. Define all your targets in a single list
local.file_match "lido_logs" {
  path_targets = [
    { __path__ = "/opt/obol-charon-zephyr/log/obol-charon-zephyr.log",             job = "charon",    __address__ = "localhost" },
    { __path__ = "/opt/obol-lodestar-zephyr/log/obol-lodestar-zephyr.log",         job = "lodestar",  __address__ = "localhost" },
    { __path__ = "/opt/mainnet-ethereum-cons-prysm/log/mainnet-ethereum-cons-prysm.log", job = "prysm",     __address__ = "localhost" },
    { __path__ = "/opt/mainnet-ethereum-exec-geth/log/mainnet-ethereum-exec-geth.log",   job = "geth",      __address__ = "localhost" },
    { __path__ = "/opt/mainnet-ethereum-mev-prysm/log/mainnet-ethereum-mev-prysm.log",   job = "mev-boost", __address__ = "localhost" },
  ]
}

// 2. Read all discovered files and forward them
loki.source.file "lido_services" {
  targets    = local.file_match.lido_logs.targets
  forward_to = [loki.write.default.receiver]
}

// 3. Write to the remote Loki instance
loki.write "default" {
  endpoint {
    url = "https://495jznuq:oZFy20v0lfbCwhEP@loki.gcp.obol.tech/loki/api/v1/push"
  }
  external_labels = {
    cluster_name = "{{ cluster_name }}",
    cluster_peer = "{{ cluster_peer }}",
  }
}
